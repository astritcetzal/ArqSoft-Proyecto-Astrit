@model MagicLibraryMVC.Models.User

<div class="contenedos-formulario">
    <h1>Iniciar Sesión</h1>
    <form asp-action="IniciarSesion" method="post">
        
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="grupo-input">
            <label>Correo</label>
            <input asp-for="Correo" />
        </div>
        <div class="grupo-input">
            <label>Contraseña</label>
            <input asp-for="Contrasena" type="password" />
        </div>
        <button type="submit" class="btn-guardar">Iniciar sesión</button>
    </form>
    <hr />
    <a asp-controller="Home" asp-action="Index" class="link-cancelar">&larr; Cancelar</a>
</div>